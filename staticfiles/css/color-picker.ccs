document.addEventListener('DOMContentLoaded', function() {
    const colorLeftField = document.querySelector('#id_color_left');
    const colorRightField = document.querySelector('#id_color_right');
    
    if (colorLeftField) {
        colorLeftField.setAttribute('type', 'color');
    }
    if (colorRightField) {
        colorRightField.setAttribute('type', 'color');
    }
});